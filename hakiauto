-- 6. ลูปตรวจสอบค่าฮาคิเพื่อ Rejoin เบื้องหลัง
-- =========================================================
task.spawn(function()
    LocalPlayer.AttributeChanged:Connect(function(attr)
        if attr == "HakiAmount" and _G.AutoFarmHaki and not isRejoining then
            local currentHaki = LocalPlayer:GetAttribute("HakiAmount") or 0
            safeTweenHakiBar(currentHaki)
            
            if currentHaki <= 0 then
                rejoinServer()
            end
        end
    end)

    while true do
        task.wait(1.5)
        if _G.AutoFarmHaki and not isRejoining then
            pcall(function()
                local currentHaki = LocalPlayer:GetAttribute("HakiAmount") or 0
                if currentHaki <= 0 then 
                    rejoinServer() 
                end
            end)
        end
    end
end)

