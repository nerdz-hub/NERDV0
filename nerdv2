local ToolTab = Window:CreateTab("Auto Use Tool", 4483345998)
ToolTab:CreateSection("Auto Drink Juice")
local autoToolRunning = false
local toolDelay = 0.5
local function getJuiceTools()
    local bp=player:FindFirstChild("Backpack") local char=player.Character local list={}
    local function chk(item) if item and item:IsA("Tool") and item.Name:find("Juice") then table.insert(list,item) end end
    if bp then for _,i in ipairs(bp:GetChildren()) do chk(i) end end
    if char then for _,i in ipairs(char:GetChildren()) do chk(i) end end
    return list
end
local function autoToolLoop()
    while autoToolRunning do
        local juices=getJuiceTools()
        if #juices==0 then task.wait(2)
        else
            for _,tool in ipairs(juices) do
                if not autoToolRunning then break end
                local char=player.Character local hum=char and char:FindFirstChildOfClass("Humanoid")
                if not hum then task.wait(0.2) continue end
                pcall(function() hum:EquipTool(tool) end) task.wait(0.2)
                local eq=char:FindFirstChild(tool.Name)
                if eq then pcall(function() eq:Activate() end) end
                task.wait(toolDelay)
            end
        end
    end
end
