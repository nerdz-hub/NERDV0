local function getBackpackTools()
    local list = {}
    local bp = player:FindFirstChild("Backpack")
    local char = player.Character
    if bp then
        for _, t in ipairs(bp:GetChildren()) do
            if t:IsA("Tool") then table.insert(list, t.Name) end
        end
    end
    if char then
        for _, t in ipairs(char:GetChildren()) do
            if t:IsA("Tool") then table.insert(list, t.Name) end
        end
    end
    return list
end

local function findAliveMonsters(nameList)
    local alive = workspace:FindFirstChild("Alive")
    if not alive then return {} end
    local nameSet = {}
    for _, n in ipairs(nameList) do nameSet[n] = true end
    local found = {}
    for _, model in ipairs(alive:GetChildren()) do
        if nameSet[model.Name] then
            local hum = model:FindFirstChildOfClass("Humanoid")
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hum and hrp and hum.Health > 0 then
                table.insert(found, { model=model, hum=hum, hrp=hrp })
            end
        end
    end
    return found
end

-- Tween char 脿赂搂脿赂聶脿赂拢脿赂颅脿赂職 mob (脿鹿聙脿赂聸脿赂楼脿赂碌脿鹿聢脿赂垄脿赂聶脿赂隆脿赂赂脿赂隆脿赂聴脿赂碌脿赂楼脿赂掳脿赂聶脿赂麓脿赂聰)
local orbitAngle = 0
local function orbitAroundMob(monHRP)
    local char = player.Character
    if not char then return end
    local myHRP = char:FindFirstChild("HumanoidRootPart")
    if not myHRP then return end
    orbitAngle = (orbitAngle + 45) % 360
    local rad = math.rad(orbitAngle)
    local offset = Vector3.new(math.cos(rad) * orbitDistance, 0, math.sin(rad) * orbitDistance)
    local targetCF = CFrame.new(monHRP.Position + offset, monHRP.Position)
    -- tween 脿赂聰脿鹿聣脿赂搂脿赂垄 TweenService
    local TweenService = game:GetService("TweenService")
    local info = TweenInfo.new(0.15, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(myHRP, info, { CFrame = targetCF })
    tween:Play()
    tween.Completed:Wait()
end

-- 脿赂聛脿赂聰脿赂陋脿赂聛脿赂麓脿赂楼 keyboard
local function fireSkills()
    local VirtualInput = game:GetService("VirtualInputManager")
    local keyMap = {
        x = Enum.KeyCode.X, c = Enum.KeyCode.C, v = Enum.KeyCode.V,
        b = Enum.KeyCode.B, n = Enum.KeyCode.N, f = Enum.KeyCode.F,
        g = Enum.KeyCode.G, h = Enum.KeyCode.H, j = Enum.KeyCode.J,
        k = Enum.KeyCode.K, l = Enum.KeyCode.L,
    }
    for _, sk in ipairs(selectedSkills) do
        local kc = keyMap[sk]
        if kc then
            pcall(function()
                VirtualInput:SendKeyEvent(true,  kc, false, game)
                task.wait(0.05)
                VirtualInput:SendKeyEvent(false, kc, false, game)
            end)
            task.wait(0.05)
        end
    end
end

-- Equip tool 脿赂聢脿赂虏脿赂聛 backpack 脿鹿聛脿赂楼脿鹿聣脿赂搂 activate
local function fireTools()
    local char = player.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end
    for _, toolName in ipairs(selectedTools) do
        local bp = player:FindFirstChild("Backpack")
        local tool = (bp and bp:FindFirstChild(toolName))
            or char:FindFirstChild(toolName)
        if tool then
            pcall(function() hum:EquipTool(tool) end)
            task.wait(0.1)
            local eq = char:FindFirstChild(toolName)
            if eq then pcall(function() eq:Activate() end) end
            task.wait(0.05)
        end
    end
end

local function attackMob(entry)
    local model = entry.model
    local hum   = entry.hum
    if not (model and hum) or hum.Health <= 0 then return end
    if v1 then
        pcall(function() v1["\t"]("MobHit",    { model, farmDamage }) end)
        pcall(function() v1["\t"]("DamageNPC", { model, farmDamage }) end)
    end
    pcall(function() hum:TakeDamage(farmDamage) end)
    fireSkills()
    fireTools()
end

local function autoFarmLoop()
    while autoFarmRunning do
        if #selectedMonsters == 0 then
            Rayfield:Notify({ Title="Farm", Content="脿赂垄脿赂卤脿赂聡脿鹿聞脿赂隆脿鹿聢脿鹿聞脿赂聰脿鹿聣脿鹿聙脿赂楼脿赂路脿赂颅脿赂聛 Monster!", Duration=2 })
            task.wait(3)
            continue
        end

        local targets = findAliveMonsters(selectedMonsters)
        if #targets == 0 then task.wait(1) continue end

        for _, entry in ipairs(targets) do
            if not autoFarmRunning then break end
            local hum = entry.hum
            local hrp = entry.hrp

            if not hum or not hrp or hum.Health <= 0 then continue end

            -- teleport 脿鹿聞脿赂聸脿鹿聝脿赂聛脿赂楼脿鹿聣 mob 脿赂聛脿鹿聢脿赂颅脿赂聶
            local char = player.Character
            local myHRP = char and char:FindFirstChild("HumanoidRootPart")
            if myHRP then
                myHRP.CFrame = hrp.CFrame * CFrame.new(0, 0, orbitDistance)
            end
            task.wait(0.05)

            -- 脿赂搂脿赂聶 tween + 脿赂聲脿赂碌 脿赂聢脿赂聶脿赂聛脿赂搂脿鹿聢脿赂虏 mob 脿赂聢脿赂掳脿赂聲脿赂虏脿赂垄
            while autoFarmRunning do
                if not hum or not hum.Parent or hum.Health <= 0 then break end
                pcall(orbitAroundMob, hrp)
                pcall(attackMob, entry)
                task.wait(farmDelay)
            end
        end
    end
end

