local JuiceTab = Window:CreateTab("Auto Juice", 4483345998)
JuiceTab:CreateSection("Juicing Bowl")
local autoJuiceRunning = false
local juiceDelay = 0.3
local function getJuiceParts()
    local path = workspace:FindFirstChild("MapFolder")
        and workspace.MapFolder:FindFirstChild("Island8")
        and workspace.MapFolder.Island8:FindFirstChild("Kitchen")
    if not path then return nil end
    local station = path:GetChildren()[2]
    if not station then return nil end
    local bowl = station:FindFirstChild("JuicingBowl")
    if not bowl then return nil end
    return { mixer=bowl:FindFirstChild("JuicingBowlMixer"), bowlPart=bowl:FindFirstChild("Bowl"), mixer1=bowl:FindFirstChild("Mixer1"), mixer2=bowl:FindFirstChild("Mixer2") }
end
local function tpToPart(part)
    local char=player.Character if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp or not part then return end
    local root if part:IsA("BasePart") then root=part else root=part.PrimaryPart or part:FindFirstChildWhichIsA("BasePart") end
    if root then hrp.CFrame=root.CFrame*CFrame.new(0,0,2) end
end
local function firePrompt(part)
    if not part then return end
    local prompt=part:FindFirstChildOfClass("ProximityPrompt")
    if not prompt then for _,c in ipairs(part:GetDescendants()) do if c:IsA("ProximityPrompt") then prompt=c break end end end
    if prompt then pcall(fireproximityprompt, prompt) end
end
local function doJuiceCycle()
    local p=getJuiceParts() if not p then Rayfield:Notify({Title="Juice",Content="脿鹿聞脿赂隆脿鹿聢脿赂聻脿赂職 JuicingBowl!",Duration=3}) return false end
    for _, part in ipairs({p.bowlPart, p.mixer1, p.mixer2, p.mixer}) do
        tpToPart(part) task.wait(juiceDelay) firePrompt(part) task.wait(juiceDelay)
    end
    return true
end
local function autoJuiceLoop()
    while autoJuiceRunning do
        local ok2,err=pcall(doJuiceCycle) if not ok2 then Rayfield:Notify({Title="Juice Error",Content=tostring(err),Duration=3}) end
        task.wait(1)
    end
end
