local FruitTab = Window:CreateTab("Auto Fruit", 4483345998)
FruitTab:CreateSection("Fruit Farmer")
local autoFruitRunning = false
local fruitDelay = 0.5
local function getFruitList()
    local fruits = workspace:FindFirstChild("MapFolder")
        and workspace.MapFolder:FindFirstChild("Fruits")
    if not fruits then return {} end
    local children = fruits:GetChildren()
    local list = {}
    local namedFruits = { "Apple", "Banana", "Cantaloupe", "Golden Apple", "Green Apple", "Melon", "Prickly Pear" }
    for _, name in ipairs(namedFruits) do
        local f = fruits:FindFirstChild(name)
        if f then table.insert(list, f) end
    end
    for _, idx in ipairs({6,7,8,10,13}) do
        if children[idx] then
            local already = false
            for _, e in ipairs(list) do if e == children[idx] then already = true break end end
            if not already then table.insert(list, children[idx]) end
        end
    end
    return list
end
local function collectFruit(fruit)
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    local root
    if fruit:IsA("BasePart") then root = fruit
    elseif fruit:IsA("Model") then root = fruit.PrimaryPart or fruit:FindFirstChildWhichIsA("BasePart")
    else root = fruit:FindFirstChildWhichIsA("BasePart") end
    if not root then return end
    root.CFrame = hrp.CFrame * CFrame.new(0, 0, -2)
    task.wait(0.05)
    local prompt = fruit:FindFirstChildOfClass("ProximityPrompt") or fruit:FindFirstChildWhichIsA("ProximityPrompt")
    if prompt then pcall(fireproximityprompt, prompt) end
end
local function autoFruitLoop()
    while autoFruitRunning do
        local fruitList = getFruitList()
        if #fruitList == 0 then
            Rayfield:Notify({ Title="Fruit", Content="脿鹿聞脿赂隆脿鹿聢脿赂聻脿赂職 Fruit!", Duration=3 })
            task.wait(5)
        else
            for _, fruit in ipairs(fruitList) do
                if not autoFruitRunning then break end
                pcall(collectFruit, fruit) task.wait(fruitDelay)
            end
        end
        task.wait(2)
    end
end
