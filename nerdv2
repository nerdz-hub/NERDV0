local function tpTo(target)
    local char = player.Character or player.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local root
    if typeof(target) == "Instance" then
        if target:IsA("BasePart") then
            root = target
        elseif target:IsA("Model") then
            root = target.PrimaryPart or target:FindFirstChildWhichIsA("BasePart")
        else
            root = target:FindFirstChildWhichIsA("BasePart")
        end
    end
    if root then
        hrp.CFrame = root.CFrame * CFrame.new(0, 0, 3)
        Rayfield:Notify({ Title="Teleport", Content="脿鹿聞脿赂聸脿赂聴脿赂碌脿鹿聢 "..target.Name.." 脿鹿聛脿赂楼脿鹿聣脿赂搂!", Duration=2 })
    else
        Rayfield:Notify({ Title="Teleport", Content="脿鹿聞脿赂隆脿鹿聢脿赂聻脿赂職 target: "..tostring(target), Duration=3 })
    end
end

